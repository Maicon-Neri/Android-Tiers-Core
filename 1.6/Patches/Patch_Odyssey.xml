<?xml version="1.0" encoding="utf-8" ?>
<Patch>
  <Operation Class="PatchOperationSequence">
    <success>Always</success>
    <operations>
      <li Class="PatchOperationAdd">
        <xpath>/Defs/*[defName and race/fleshType="AndroidTier"]/statBases</xpath>
        <value>
          <VacuumResistance MayRequire="Ludeon.RimWorld.Odyssey">1</VacuumResistance>
        </value>
      </li>
      <li Class="PatchOperationAdd">
        <xpath>/Defs/*[defName and race/fleshType="AndroidTier"]/race</xpath>
        <value>
          <canBeVacuumBurnt>false</canBeVacuumBurnt>
        </value>
      </li>
    </operations>
  </Operation>
</Patch>
